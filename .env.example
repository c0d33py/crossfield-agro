# Copy to .env and fill in real values. Never commit .env.

# ---- Core ----
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
SITE_DOMAIN=localhost:8000

# ---- Database (postgres://USER:PASS@HOST:PORT/DB) ----
DATABASE_URL=postgres://crosfield:crosfield@localhost:5432/crosfield_agro
DB_CONN_MAX_AGE=60

# ---- Cache / Celery ----
REDIS_URL=redis://127.0.0.1:6379/1
CELERY_BROKER_URL=redis://127.0.0.1:6379/2
CELERY_TASK_ALWAYS_EAGER=False

# ---- Admin (production: move off /admin/) ----
ADMIN_URL=staff-portal-CHANGE-ME/

# ---- Email (production) ----
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@crosfieldagro.com.pk

# ---- Sentry (production) ----
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ---- Logging ----
LOG_LEVEL=INFO

# ---- Payment gateways (add as integrated) ----
# JAZZCASH_PUBLIC_KEY=
# JAZZCASH_SECRET_KEY=
# JAZZCASH_WEBHOOK_SECRET=
# EASYPAISA_PUBLIC_KEY=
# EASYPAISA_SECRET_KEY=
# EASYPAISA_WEBHOOK_SECRET=
